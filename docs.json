{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "OpenClaw Code",
  "colors": {
    "primary": "#ef4444",
    "light": "#ef4444",
    "dark": "#b91c1c"
  },
  "favicon": "/favicon.ico",
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "icon": "browser",
          "href": "https://openclawcode.org"
        },
        {
          "anchor": "GitHub",
          "icon": "message-code",
          "href": "https://github.com/damoahdominic/occ"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "How OCCode Works",
            "pages": [
              "inference",
              "billing"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://occ.mba.sh/dashboard"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Download",
      "href": "https://openclawcode.org/#download"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/damoahdominic/occ",
      "x": "https://x.com/openclawcode"
    }
  }
}
